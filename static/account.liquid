{{ index_for_top_components }}
{% render 'theme_breadcrumbs' %}

{% if customer %}
<div class="gq-account-wrapper">
    <div class="gq-account-hero">
        <div class="gq-hero-content">
            <div class="gq-avatar">
                <div class="gq-avatar-circle">{{ customer.name | slice: 0, 2 | upcase }}</div>
            </div>
            <div class="gq-hero-info">
                <h1 class="gq-welcome">Bienvenido de vuelta</h1>
                <p class="gq-customer-name">{{ customer.name }} {{ customer.surname }}</p>
            </div>
        </div>
    </div>

    <div class="gq-points-card">
        <div class="gq-card-header">
            <div class="gq-card-icon">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                    <circle cx="24" cy="24" r="24" fill="#FFF8E1"/>
                    <path d="M14 26C14 23.79 18.47 22 24 22C29.52 22 34 23.79 34 26V31C34 33.2 29.52 35 24 35C18.47 35 14 33.2 14 31V26Z" fill="#FFC107"/>
                    <path d="M14 19C14 16.79 18.47 15 24 15C29.52 15 34 16.79 34 19V24C34 26.2 29.52 28 24 28C18.47 28 14 26.2 14 24V19Z" fill="#FFD54F" stroke="#FFA000" stroke-width="2"/>
                </svg>
            </div>
            <div class="gq-card-title">
                <h2>Tus QuestPoints</h2>
                <p>Programa de fidelización GameQuest</p>
            </div>
        </div>

        <div class="gq-balance-display">
            <span class="gq-balance-label">Saldo Disponible</span>
            <div class="gq-balance-amount" id="gq-balance-display">
                <span class="gq-loading">Cargando...</span>
            </div>
            <span class="gq-balance-subtitle">Puntos acumulados en tus compras</span>
        </div>

        <div class="gq-action-zone">
            <div class="gq-custom-redeem-wrapper">
                <div class="gq-input-container">
                    <label class="gq-input-label">Monto a canjear:</label>
                    <div style="position: relative;">
                        <span class="gq-input-currency">$</span>
                        <input type="number" id="gq-input-amount" class="gq-number-input" value="100" min="100" disabled>
                    </div>
                </div>
                
                <button class="gq-btn-primary" id="gq-btn-redeem" disabled>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                        <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
                    </svg>
                    <span id="gq-btn-text">Cargando...</span>
                </button>
            </div>

            <p class="gq-info-text">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
                </svg>
                Mínimo para canjear: $100 CLP. Puedes personalizar el monto exacto.
            </p>
        </div>

        <div class="gq-stats-grid">
            <div class="gq-stat-item">
                <span class="gq-stat-label">Total Canjeado</span>
                <span class="gq-stat-value" id="gq-total-redeemed">$0</span>
            </div>
            <div class="gq-stat-item">
                <span class="gq-stat-label">Estado</span>
                <span class="gq-stat-badge">
                    <span class="gq-badge-dot"></span>
                    Activo
                </span>
            </div>
        </div>

        <!-- ── Último Canje registrado ───────────────────────────── -->
        <div class="gq-last-canje" id="gq-last-canje" style="display:none;">
            <div class="gq-last-canje-inner">
                <span class="gq-last-label">Último Canje</span>
                <div class="gq-last-body">
                    <span class="gq-last-amount" id="gq-last-amount"></span>
                    <span class="gq-last-code"   id="gq-last-code" title="Clic para copiar" onclick="gqCopyLastCode()"></span>
                    <span class="gq-last-adj"    id="gq-last-adj"  style="display:none;">ajustado</span>
                </div>
                <span class="gq-last-date" id="gq-last-date"></span>
            </div>
        </div>
    </div>

    <div class="gq-info-section">
        <h3 class="gq-section-title">¿Cómo funcionan los QuestPoints?</h3>
        <div class="gq-info-grid">
            <div class="gq-info-card">
                <div class="gq-info-number">1</div>
                <h4>Compra en GameQuest</h4>
                <p>Por cada compra acumulas puntos automáticamente (1% del valor)</p>
            </div>
            <div class="gq-info-card">
                <div class="gq-info-number">2</div>
                <h4>Acumula Puntos</h4>
                <p>Tus puntos se suman a tu cuenta sin necesidad de hacer nada</p>
            </div>
            <div class="gq-info-card">
                <div class="gq-info-number">3</div>
                <h4>Canjea por Descuentos</h4>
                <p>Elige cuánto de tu saldo usar y genera tu cupón en segundos</p>
            </div>
        </div>
    </div>
</div>

<style>
/* --- ESTILOS VISUALES --- */
.gq-account-wrapper { max-width: 900px; margin: 40px auto; padding: 0 20px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
.gq-account-hero { background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%); border-radius: 20px; padding: 30px; margin-bottom: 30px; box-shadow: 0 10px 40px rgba(0,0,0,.2); }
.gq-hero-content { display: flex; align-items: center; gap: 20px; }
.gq-avatar { flex-shrink: 0; }
.gq-avatar-circle { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg,#FFC107,#FF9800); display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: 800; color: #1a1a1a; box-shadow: 0 4px 20px rgba(255,193,7,.4); }
.gq-hero-info { flex-grow: 1; }
.gq-welcome { font-size: 14px; font-weight: 600; color: #999; margin: 0 0 8px; text-transform: uppercase; letter-spacing: 1px; }
.gq-customer-name { font-size: 28px; font-weight: 800; color: #fff; margin: 0; }
.gq-points-card { background: #fff; border-radius: 20px; padding: 40px; box-shadow: 0 4px 20px rgba(0,0,0,.08); margin-bottom: 30px; }
.gq-card-header { display: flex; align-items: center; gap: 20px; margin-bottom: 30px; padding-bottom: 30px; border-bottom: 2px solid #f0f0f0; }
.gq-card-icon { flex-shrink: 0; }
.gq-card-title h2 { font-size: 24px; font-weight: 800; color: #1a1a1a; margin: 0 0 5px; }
.gq-card-title p { font-size: 14px; color: #666; margin: 0; }
.gq-balance-display { text-align: center; margin: 40px 0; }
.gq-balance-label { display: block; font-size: 12px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; }
.gq-balance-amount { font-size: 64px; font-weight: 900; color: #1a1a1a; line-height: 1; margin-bottom: 10px; font-family: 'Courier New', monospace; }
.gq-loading { font-size: 32px; color: #ccc; animation: pulse 1.5s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.5} }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }
.gq-balance-subtitle { display: block; font-size: 14px; color: #666; }

.gq-action-zone { margin: 40px 0; padding: 30px; background: #fafafa; border-radius: 16px; border: 1px solid #eee; }
.gq-custom-redeem-wrapper { display: flex; justify-content: center; align-items: flex-end; gap: 15px; flex-wrap: wrap; margin-bottom: 15px; }
.gq-input-container { text-align: left; max-width: 200px; width: 100%; }
.gq-input-label { display: block; font-size: 12px; font-weight: 700; color: #666; text-transform: uppercase; margin-bottom: 8px; }
.gq-input-currency { position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #999; font-weight: bold; font-size: 18px; }
.gq-number-input { width: 100%; padding: 16px 15px 16px 35px; border-radius: 12px; border: 2px solid #ddd; font-size: 20px; font-weight: 800; color: #1a1a1a; outline: none; transition: all 0.3s; background: #fff; }
.gq-number-input:focus { border-color: #FFC107; box-shadow: 0 0 0 4px rgba(255,193,7,0.15); }
.gq-number-input:disabled { background: #f0f0f0; color: #aaa; cursor: not-allowed; }

.gq-btn-primary { height: 62px; background: linear-gradient(135deg,#1a1a1a,#2d2d2d); color: #fff; border: none; padding: 0 35px; font-size: 16px; font-weight: 700; border-radius: 12px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 10px; transition: all .3s; box-shadow: 0 4px 15px rgba(0,0,0,.2); white-space: nowrap; }
.gq-btn-primary:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,0,0,.3); background: #000; }
.gq-btn-primary:disabled { background: #e0e0e0; color: #999; cursor: not-allowed; box-shadow: none; transform: none; }
.gq-info-text { margin-top: 20px; font-size: 13px; color: #666; display: flex; align-items: center; justify-content: center; gap: 8px; text-align: center; }

.gq-stats-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 20px; margin-top: 30px; padding-top: 30px; border-top: 2px solid #f0f0f0; }
.gq-stat-item { text-align: center; }
.gq-stat-label { display: block; font-size: 12px; color: #999; text-transform: uppercase; letter-spacing: .5px; margin-bottom: 8px; }
.gq-stat-value { display: block; font-size: 24px; font-weight: 800; color: #1a1a1a; }
.gq-stat-badge { display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; background: #e8f5e9; color: #2e7d32; border-radius: 20px; font-size: 14px; font-weight: 600; }
.gq-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: #4caf50; animation: blink 2s ease-in-out infinite; }
.gq-info-section { margin-top: 40px; }
.gq-section-title { font-size: 20px; font-weight: 800; color: #1a1a1a; margin-bottom: 25px; text-align: center; }
.gq-info-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
.gq-info-card { background: #fff; padding: 30px; border-radius: 16px; text-align: center; box-shadow: 0 2px 10px rgba(0,0,0,.05); border: 1px solid #f0f0f0; transition: all .3s; }
.gq-info-card:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(0,0,0,.1); }
.gq-info-number { width: 50px; height: 50px; border-radius: 50%; background: linear-gradient(135deg,#FFC107,#FF9800); color: #fff; font-size: 24px; font-weight: 800; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; }
.gq-info-card h4 { font-size: 16px; font-weight: 700; color: #1a1a1a; margin: 0 0 10px; }
.gq-info-card p { font-size: 14px; color: #666; line-height: 1.6; margin: 0; }
.gq-last-canje { margin-top: 24px; padding-top: 24px; border-top: 2px solid #f0f0f0; }
.gq-last-canje-inner { display: flex; flex-direction: column; align-items: center; gap: 6px; text-align: center; }
.gq-last-label { font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: .8px; }
.gq-last-body { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: center; }
.gq-last-amount { font-size: 18px; font-weight: 800; color: #1a1a1a; }
.gq-last-code { font-family: 'Courier New', monospace; font-size: 13px; font-weight: 700; color: #92400e;
                background: #fefce8; border: 1px solid #fde68a; border-radius: 6px;
                padding: 3px 10px; cursor: pointer; transition: background .2s; }
.gq-last-code:hover { background: #fde68a; }
.gq-last-adj { font-size: 10px; font-weight: 700; color: #b45309; background: #fef3c7;
               border: 1px solid #fde68a; border-radius: 4px; padding: 1px 6px; }
.gq-last-date { font-size: 11px; color: #aaa; }
@media(max-width:768px){
    .gq-custom-redeem-wrapper { flex-direction: column; align-items: stretch; }
    .gq-input-container { max-width: 100%; }
    .gq-account-hero{padding:20px}
    .gq-avatar-circle{width:60px;height:60px;font-size:24px}
    .gq-customer-name{font-size:20px}
    .gq-points-card{padding:25px}
    .gq-balance-amount{font-size:48px}
    .gq-info-grid,.gq-stats-grid{grid-template-columns:1fr}
}
</style>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
(function () {
const GAMECOINS_API_URL = "https://gamecoins.onrender.com";
const GQ_EMAIL = "{{ customer.email | downcase | strip }}";
const GQ_TOKEN = "f98yWtYyIpvJDjLhnssu8ntuKfFSnA7NSft0NoaFZIE";
const MIN_REDEEM = 100;
let currentBalance = 0;

const fmt = (n) => new Intl.NumberFormat('es-CL', {
    style: 'currency', currency: 'CLP', minimumFractionDigits: 0
}).format(n);

async function gqLoadBalance() {
        const _balCtrl = new AbortController();
        const _balTimer = setTimeout(() => _balCtrl.abort(), 8000);
        try {const res = await fetch(`${GAMECOINS_API_URL}/api/public/balance/${encodeURIComponent(GQ_EMAIL)}`, {method: 'GET', headers: {'x-store-token': GQ_TOKEN}, signal: _balCtrl.signal});
        clearTimeout(_balTimer);
        if (!res.ok) throw new Error('Error al cargar saldo');
        const data = await res.json();

        currentBalance = data.saldo || 0;
        
        document.getElementById('gq-balance-display').innerHTML = fmt(currentBalance);
        const redeemedEl = document.getElementById('gq-total-redeemed');
        if (redeemedEl) redeemedEl.textContent = fmt(data.historico_canjeado || 0);

        const btn = document.getElementById('gq-btn-redeem');
        const btnText = document.getElementById('gq-btn-text');
        const inputAmount = document.getElementById('gq-input-amount');

        if (currentBalance >= MIN_REDEEM) {
            btn.disabled = false;
            inputAmount.disabled = false;
            inputAmount.max = Math.floor(currentBalance);
            inputAmount.value = Math.floor(currentBalance);
            btnText.textContent = 'Canjear Puntos';
        } else {
            btn.disabled = true;
            inputAmount.disabled = true;
            inputAmount.value = currentBalance;
            btnText.textContent = 'Saldo Insuficiente';
        }

    } catch (err) {
        console.error('Error cargando saldo:', err);
        document.getElementById('gq-balance-display').innerHTML = '$0';
        document.getElementById('gq-btn-text').textContent = 'Sin datos';
    }
}

async function gqRedeemPoints() {
    const inputAmountEl = document.getElementById('gq-input-amount');
    const cantidadSeleccionada = Math.floor(Number(inputAmountEl.value));

    if (isNaN(cantidadSeleccionada) || cantidadSeleccionada < MIN_REDEEM) {
        Swal.fire("Monto Inválido", `El monto mínimo a canjear es de ${fmt(MIN_REDEEM)} CLP.`, "warning");
        return;
    }
    
    if (cantidadSeleccionada > currentBalance) {
        Swal.fire("Saldo Insuficiente", `No puedes canjear más de tu saldo disponible (${fmt(currentBalance)} CLP).`, "error");
        return;
    }

    const result = await Swal.fire({
        title: '¿Confirmar Canje?',
        text: `¿Estás seguro de canjear ${fmt(cantidadSeleccionada)} por un cupón de descuento? Esta acción no se puede deshacer.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#1a1a1a',
        cancelButtonColor: '#d33',
        confirmButtonText: 'Sí, generar cupón',
        cancelButtonText: 'Cancelar'
    });

    if (!result.isConfirmed) return;

    const btn = document.getElementById('gq-btn-redeem');
    const btnText = document.getElementById('gq-btn-text');
    btn.disabled = true;
    inputAmountEl.disabled = true;
    btnText.textContent = 'Generando Cupón...';

    try {
        const _canjeCtrl = new AbortController();
        const _canjeTimer = setTimeout(() => _canjeCtrl.abort(), 15000);
        const res = await fetch(`${GAMECOINS_API_URL}/api/canje`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'x-store-token': GQ_TOKEN
            },
            body: JSON.stringify({
                email: GQ_EMAIL,
                monto: cantidadSeleccionada,
                cart_total: cantidadSeleccionada
            }),
            signal: _canjeCtrl.signal
        });
        clearTimeout(_canjeTimer);

        const data = await res.json();

        if (res.ok && data.status === 'ok') {
            const cuponGenerado = data.cupon_codigo;

            // Al cerrar la alerta, recargamos para actualizar el saldo
            const mostrarExito = () => {
                Swal.fire({
                    title: '¡Canje Exitoso!',
                    html: `
                        <p>Tu cupón por <b>${fmt(cantidadSeleccionada)}</b> es:</p>
                        <h2 style="color: #FFC107; font-weight: 900; letter-spacing: 2px; margin: 15px 0;">${cuponGenerado}</h2>
                        <p style="color: #28a745; font-size: 0.9em; margin-bottom: 10px;">📋 ¡Copiado al portapapeles automáticamente!</p>
                        <p style="font-size: 0.85em; color: #666;">Ya puedes pegarlo en la casilla de descuentos de tu compra.</p>
                    `,
                    icon: 'success',
                    confirmButtonColor: '#1a1a1a',
                    confirmButtonText: 'Aceptar',
                    allowOutsideClick: false
                }).then(() => {
                    window.location.reload();
                });
            };

            // Intentar copiar al portapapeles
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(cuponGenerado).then(() => {
                    mostrarExito();
                }).catch(err => {
                    mostrarExito(); 
                });
            } else {
                mostrarExito();
            }

        } else {
            Swal.fire("Error", data.detail || 'Error al procesar el canje.', "error");
            btn.disabled = false;
            inputAmountEl.disabled = false;
            btnText.textContent = 'Canjear Puntos';
        }

    } catch (err) {
        console.error('Error canjeando:', err);
        Swal.fire("Error de conexión", "Verifica tu internet e intenta nuevamente.", "error");
        btn.disabled = false;
        inputAmountEl.disabled = false;
        btnText.textContent = 'Canjear Puntos';
    }
}

async function gqLoadLastCanje() {
    try {
        const _c = new AbortController();
        const _t = setTimeout(() => _c.abort(), 8000);
        const r = await fetch(
            `${GAMECOINS_API_URL}/api/public/last_canje/${encodeURIComponent(GQ_EMAIL)}`,
            { method: 'GET', headers: { 'x-store-token': GQ_TOKEN }, signal: _c.signal }
        );
        clearTimeout(_t);
        if (!r.ok) return;
        const d = await r.json();
        if (!d.found) return;

        const container = document.getElementById('gq-last-canje');
        const amountEl  = document.getElementById('gq-last-amount');
        const codeEl    = document.getElementById('gq-last-code');
        const adjEl     = document.getElementById('gq-last-adj');
        const dateEl    = document.getElementById('gq-last-date');

        if (!container || !amountEl || !codeEl || !dateEl) return;

        amountEl.textContent = fmt(d.amount_qp || 0);
        codeEl.textContent   = d.coupon_code || '';
        codeEl.dataset.code  = d.coupon_code || '';

        if (d.adjusted) {
            adjEl.style.display = 'inline';
            adjEl.title = `Solicitaste ${fmt(d.monto_original || 0)}, se ajustó al máximo disponible`;
        }

        if (d.created_at) {
            const fecha = new Date(d.created_at);
            dateEl.textContent = fecha.toLocaleString('es-CL', {
                day: '2-digit', month: '2-digit', year: '2-digit',
                hour: '2-digit', minute: '2-digit'
            });
        }

        container.style.display = 'block';
    } catch (err) {
        if (err.name !== 'AbortError') console.warn('GameCoins: último canje no disponible', err);
    }
}

function gqCopyLastCode() {
    const code = document.getElementById('gq-last-code');
    if (!code) return;
    const txt = code.dataset.code || code.textContent;
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(txt).then(() => {
            Swal.fire({ icon:'success', title:'Código copiado', text: txt,
                        timer: 1500, showConfirmButton: false, toast: true, position: 'top-end' });
        }).catch(() => { Swal.fire({ title:'Código del cupón', text: txt }); });
    } else {
        Swal.fire({ title:'Código del cupón', text: txt });
    }
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => { gqLoadBalance(); gqLoadLastCanje(); });
} else {
    gqLoadBalance(); gqLoadLastCanje();
}

// Registrar handler del botón dentro del scope de la IIFE
// (no puede ser onclick="gqRedeemPoints()" global — quedaría fuera del scope)
const _gqBtn = document.getElementById('gq-btn-redeem');
if (_gqBtn) _gqBtn.addEventListener('click', gqRedeemPoints);

})();
</script>
{% endif %}

{{- index_for_components -}}