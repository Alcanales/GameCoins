{% assign is_checkout_page = false %}
{% if template == 'cart' or template == 'checkout' or template == 'revieworder' or template == 'success' %}
  {% assign is_checkout_page = true %}
{% endif %}
{% assign is_customer_page = false %}
{% if template == 'customer_account' or template == 'customer_address' or template == 'customer_details' or template == 'customer_login' or template == 'customer_reset_password' %}
  {% assign is_customer_page = true %}
{% endif %}
{% assign is_category_page = false %}
{% if template == 'category' or template == 'searchresults' %}
  {% assign is_category_page = true %}
{% endif %}
<!doctype html>

<html class="no-js" lang="{{ languages.first.locale }}" xmlns="http://www.w3.org/1999/xhtml">
  <head>

    {{ options.head_code_top }}

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title }}</title>
    <meta name="description" content="{{ meta_description | default: store.name }}">
    <meta name="robots" content="follow, all">
    <meta name="google-site-verification" content="qn-Gx4sDY5Aiv0tH6WtvuEBTdTf3sLOvwsa6vKr72qg">

    <link rel="preconnect" href="https://images.jumpseller.com">
    <link rel="preconnect" href="https://cdnx.jumpseller.com">
    <link rel="preconnect" href="https://assets.jumpseller.com">
    <link rel="preconnect" href="https://files.jumpseller.com">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    {% render 'og_meta_tags' %}

    {% for language in languages %}
      <link rel="alternate" {% if languages.size > 1 %}
          hreflang="{{ language.locale }}"
        {% endif %} href="{{ language.url }}">
    {% endfor %}

    <link rel="canonical" href="{{ canonical_url }}">

    {{ favicon }}

    <!-- jQuery -->
    {{ 'jquery/3.7.1/jquery.min.js' | public_asset_tag: 'defer' }}

    <!-- Bootstrap -->
    {{ 'bootstrap/5.3.3/bootstrap.bundle.min.css' | public_asset_tag }}

    <!-- Youtube-Background -->
    {{ 'youtube-background/1.1.8/jquery.youtube-background.min.js' | public_asset_tag: 'defer' }}

    {% if store.autocomplete_access %}
      <!-- Autocomplete search -->
      {{ 'autocomplete/1.16.0/index.production.min.js' | public_asset_tag: 'defer' }}
      <script src="//assets.jumpseller.com/public/autocomplete/jumpseller-autocomplete@1.0.0.min.js" data-suggest-categories="false" defer></script>
    {% endif %}

    {% unless template == 'success' %}
      <!-- Swiper -->
      {{ 'swiper/11.2.7/swiper-bundle.min.css' | public_asset_tag }}
      {{ 'swiper/11.2.7/swiper-bundle.min.js' | public_asset_tag: 'defer' }}
    {% endunless %}

    {% render 'schema' %}

    {% style %}
      {% assign font_parsed_main = options.font_main | split: "," | first | strip | url_encode %}
      {% assign font_parsed_secondary = options.font_secondary | split: "," | first | strip | url_encode %}
      {% assign font_parsed_store_name = options.font_store_name | split: "," | first | strip | url_encode %}
      {% assign font_parsed_buttons = options.font_buttons | split: "," | first | strip | url_encode %}

      {% assign font_weights = 'ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800' %}
      {% assign fonts_array = font_parsed_main | append: ',' | append: font_parsed_secondary | append: ',' | append: font_parsed_store_name | append: ',' | append: font_parsed_buttons | split: ',' | uniq %}
      {% assign fonts_query = "" %}
      {% for font_encoded in fonts_array %}
        {% if font_encoded != "" %}
          {% if fonts_query != "" %}
            {% assign fonts_query = fonts_query | append: '&' %}
          {% endif %}
          {% assign fonts_query = fonts_query | append: 'family=' | append: font_encoded | append: ':' | append: font_weights %}
        {% endif %}
      {% endfor %}
      {% if fonts_query != "" %}
        @import url('https://fonts.googleapis.com/css2?{{ fonts_query }}&display=swap');
      {% endif %}

      @import url('https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css');
      {% if options.theme_icon_style != 'regular' %}
        @import url('https://unpkg.com/@phosphor-icons/web@2.1.1/src/{{ options.theme_icon_style }}/style.css');
      {% endif %}

      :root {
        --theme-icon-style: var(--icon-style-{{ options.theme_icon_style | default: 'regular' }});
        --font-main: {{ options.font_main }};
        --font-secondary: {{ options.font_secondary }};
        --font-store-name: {{ options.font_store_name }};
        --font-buttons: {{ options.font_buttons }};
        --font-base-size: {{ options.font_base_size }}px;
        --subtitle-size-desktop-number: 0.4;
        --subtitle-size-mobile-number: 0.3;
        {% if options.heading_title_size == 'custom' %}
          --title-size-desktop: {{ options.heading_title_size_desktop }}px;
          --title-size-mobile: {{ options.heading_title_size_mobile }}px;
          --subtitle-size-desktop: {{ options.heading_subtitle_size_desktop }}px;
          --subtitle-size-mobile: {{ options.heading_subtitle_size_mobile }}px;
        {% else %}
          --title-size-desktop: var(--title-size-{{ options.heading_title_size | default: 'medium' }}-desktop);
          --title-size-mobile: var(--title-size-{{ options.heading_title_size | default: 'medium' }}-mobile);
          --subtitle-size-desktop: calc(var(--title-size-desktop) * var(--subtitle-size-desktop-number));
          --subtitle-size-mobile: calc(var(--title-size-mobile) * var(--subtitle-size-mobile-number));
        {% endif %}
        --title-weight: {{ options.heading_title_weight }};
        --title-spacing: {{ options.heading_title_spacing }}px;
        --title-text-transform: {% if options.heading_title_uppercase %}uppercase{% else %}initial{% endif %};
        {% if options.heading_description_size == 'custom' %}
          --description-size-desktop: {{ options.heading_description_size_desktop }}px;
          --description-size-mobile: {{ options.heading_description_size_mobile }}px;
        {% else %}
          --description-size-desktop: var(--description-size-{{ options.heading_description_size | default: 'medium' }}-desktop);
          --description-size-mobile: var(--description-size-{{ options.heading_description_size | default: 'medium' }}-mobile);
        {% endif %}
        --subtitle-weight: {{ options.heading_subtitle_weight }};
        --subtitle-spacing: {{ options.heading_subtitle_spacing }}px;
        --subtitle-text-transform: {% if options.heading_subtitle_uppercase %}uppercase{% else %}initial{% endif %};
        --store-name-size-desktop: var(--store-name-desktop-{{ options.theme_store_name_size }});
        --store-name-size-mobile: var(--store-name-mobile-{{ options.theme_store_name_size }});
        --store-name-weight: {{ options.theme_store_name_weight }};

        {% case options.theme_corners_style %}
          {% when 'rectangular' %}
            --radius-style: 0px;
            --radius-style-adapt: 0px;
            --radius-style-inner: 0px;
            --pb-radius-style: 0px;
            --pb-radius-style-inner: 0px;
            --article-block-radius-style: 0px;
            --article-block-radius-style-adapt: 0px;
          {% when 'rounded' %}
            --radius-style: 5px;
            --radius-style-adapt: var(--radius-style);
            --radius-style-inner: calc(var(--radius-style) * 0.5);
            {% if options.pb_corners %}
              --pb-radius-style: var(--radius-style);
              --pb-radius-style-inner: var(--radius-style-inner);
            {% else %}
              --pb-radius-style: 0px;
              --pb-radius-style-inner: 0px;
            {% endif %}
            {% if options.article_block_corners %}
              --article-block-radius-style: var(--radius-style);
              --article-block-radius-style-adapt: var(--radius-style-adapt);
            {% else %}
              --article-block-radius-style: 0px;
              --article-block-radius-style-adapt: 0px;
            {% endif %}
          {% when 'rounded-large' %}
            --radius-style: 15px;
            --radius-style-adapt: calc(var(--radius-style) * 0.5);
            --radius-style-inner: calc(var(--radius-style) * 0.5);
            {% if options.pb_corners %}
              --pb-radius-style: var(--radius-style);
              --pb-radius-style-inner: var(--radius-style-inner);
            {% else %}
              --pb-radius-style: 0px;
              --pb-radius-style-inner: 0px;
            {% endif %}
            {% if options.article_block_corners %}
              --article-block-radius-style: var(--radius-style);
              --article-block-radius-style-adapt: var(--radius-style-adapt);
            {% else %}
              --article-block-radius-style: 0px;
              --article-block-radius-style-adapt: 0px;
            {% endif %}
        {% endcase %}

        {% case options.theme_button_style %}
          {% when 'circular' %}
            --button-style: 200px;
          {% when 'rectangular' %}
            --button-style: 0px;
          {% when 'rounded' %}
            --button-style: calc(var(--font-base-size) * 0.5);
          {% when 'rounded-large' %}
            --button-style: calc(var(--font-base-size) * 1);
        {% endcase %}
        --button-transform: {{ options.theme_button_transform }};

        {% if options.theme_spacing == 'none' %}
          --theme-section-padding: 0;
          --theme-block-padding: 0;
          --section-content-margin: calc(-0.75 * var(--font-base-size));
          --section-content-padding: calc(var(--font-base-size) * 0.75);
          --theme-block-wrapper-gap: calc(var(--section-content-padding) * 2);
        {% else %}
          --theme-section-padding: var(--theme-section-padding-{{ options.theme_spacing }});
          --theme-block-padding: var(--theme-block-padding-{{ options.theme_spacing }});
          --section-content-margin: calc(-1 * var(--theme-block-padding));
          --section-content-padding: var(--theme-block-padding);
          --theme-block-wrapper-gap: calc(var(--theme-block-padding) * 2);
        {% endif %}
        --theme-block-padding-inner: calc(var(--font-base-size) * 0.75);

        --theme-border-style: {{ options.theme_border_style }};
        --theme-border-thickness: {{ options.theme_border_thickness | default: 'thin' | replace: 'thin', '1px' | replace: 'thick', '2px' }};
        --theme-button-hover-size: {{ options.theme_button_hover_size }}px;

        --button-font-size-desktop: {{ options.theme_button_size_desktop }}px;
        --button-font-size-mobile: {{ options.theme_button_size_mobile }}px;

        --theme-heading-underline-thickness-desktop: {{ options.heading_title_underline_thickness_desktop }}px;
        --theme-heading-underline-thickness-mobile: {{ options.heading_title_underline_thickness_mobile }}px;
        --theme-heading-underline-width-desktop: {{ options.heading_title_underline_width_desktop }}px;
        --theme-heading-underline-width-mobile: {{ options.heading_title_underline_width_mobile }}px;

        --cart-header-logo-height-desktop: {{ options.cart_logo_height_desktop }}px;
        --cart-header-logo-height-mobile: {{ options.cart_logo_height_mobile }}px;

        {% case options.theme_spacing %}
          {% when 'medium' %}
            --pb-padding: calc(var(--font-base-size) * 0.625);
          {% when 'large' %}
            --pb-padding: calc(var(--font-base-size) * 0.75);
          {% else %}
            --pb-padding: calc(var(--font-base-size) * 0.5);
        {% endcase %}
        --pb-alignment: {{ options.pb_alignment }};
        {% if options.pb_name_size == 'custom' %}
          --pb-font-size-desktop: {{ options.pb_name_size_desktop }}px;
          --pb-font-size-mobile: {{ options.pb_name_size_mobile }}px;
        {% else %}
          --pb-font-size-desktop: calc(var(--font-base-size) * 1);
          --pb-font-size-mobile: calc(var(--font-base-size) * 1);
        {% endif %}
        --pb-name-weight: {{ options.pb_name_weight }};
        --pb-name-spacing: {{ options.pb_name_spacing }}px;
        --pb-name-text-transform: {% if options.pb_name_uppercase %}uppercase{% else %}initial{% endif %};
        {% if options.pb_labels_font_size == 'custom' %}
          --pb-labels-font-size-desktop: {{ options.pb_labels_font_size_desktop }}px;
          --pb-labels-font-size-mobile: {{ options.pb_labels_font_size_mobile }}px;
        {% else %}
          --pb-labels-font-size-desktop: calc(var(--font-base-size) * 0.7);
          --pb-labels-font-size-mobile: calc(var(--font-base-size) * 0.7);
        {% endif %}
        --pb-color-label-status-bg: {{ options.pb_label_status_background }};
        --pb-color-label-status-text: {{ options.pb_label_status_text }};
        --pb-color-label-status-border: {{ options.pb_label_status_text | color_opacity: 0.1 }};
        --pb-color-label-new-bg: {{ options.pb_label_new_color_background }};
        --pb-color-label-new-text: {{ options.pb_label_new_color_text }};
        --pb-image-dimension: var(--aspect-ratio-{{ options.pb_image_dimension }});
        {% case options.pb_color_options_style %}
          {% when 'circular' %}
            --pb-colors-style-outer: 20px;
            --pb-colors-style-inner: 20px;
          {% when 'rectangular' %}
            --pb-colors-style-outer: 0px;
            --pb-colors-style-inner: 0px;
          {% when 'rounded' %}
            --pb-colors-style-outer: 5px;
            --pb-colors-style-inner: 3px;
        {% endcase %}
        {% if options.pb_color_options_image %}
          --pb-colors-size-desktop: 28px;
          --pb-colors-size-mobile: 22px;
        {% else %}
          --pb-colors-size-desktop: 20px;
          --pb-colors-size-mobile: 16px;
        {% endif %}
        {% if options.pb_actions_font_size == 'custom' %}
          --pb-actions-font-size-desktop: {{ options.pb_actions_font_size_desktop }}px;
          --pb-actions-font-size-mobile: {{ options.pb_actions_font_size_mobile }}px;
        {% else %}
          --pb-actions-font-size-desktop: calc(var(--pb-font-size-desktop) * 2.5);
          --pb-actions-font-size-mobile: calc(var(--pb-font-size-mobile) * 2);
        {% endif %}
        --pb-card-border-opacity: {{ options.pb_card_border_opacity | divided_by: 100.00 }};

        {% case options.theme_spacing %}
          {% when 'none' %}
            --article-block-content-padding: calc(var(--font-base-size) * 0.75);
          {% when 'small' %}
            --article-block-content-padding: calc(var(--font-base-size) * 0.5);
          {% when 'medium' %}
            --article-block-content-padding: calc(var(--font-base-size) * 0.625);
          {% when 'large' %}
            --article-block-content-padding: calc(var(--font-base-size) * 0.75);
        {% endcase %}
        {% if options.article_block_title_size == 'custom' %}
          --article-block-font-size-desktop: {{ options.article_block_title_size_desktop }}px;
          --article-block-font-size-mobile: {{ options.article_block_title_size_mobile }}px;
          --article-block-line-height: calc(var(--article-block-font-size-desktop) * 1.26);
          --article-block-line-height-excerpt: calc(var(--article-block-line-height) * 0.8);
        {% else %}
          --article-block-font-size-desktop: calc(var(--font-base-size) * 1.3125);
          --article-block-font-size-mobile: calc(var(--font-base-size) * 1.125);
          --article-block-line-height: var(--font-base-line-height);
          --article-block-line-height-excerpt: calc(var(--article-block-line-height) * 0.8);
        {% endif %}
        --article-block-title-weight: {{ options.article_block_title_weight }};
        --article-block-title-spacing: {{ options.article_block_title_spacing }}px;
        --article-block-title-transform: {% if options.article_block_title_uppercase %}uppercase{% else %}initial{% endif %};
        --article-block-border-opacity: {{ options.article_block_border_opacity | divided_by: 100.0 }};

        --store-whatsapp-spacing: 1rem;
        --store-whatsapp-color-icon: {{ options.store_whatsapp_color_icon }};
        --store-whatsapp-color-bg: {{ options.store_whatsapp_color_background }};
        --store-whatsapp-color-bg-hover: {{ options.store_whatsapp_color_background_hover }};
        --store-whatsapp-color-message-text: {{ options.store_whatsapp_message_color_text }};
        --store-whatsapp-color-message-bg: {{ options.store_whatsapp_message_color_background }};
        --store-whatsapp-color-message-shadow: {{ options.store_whatsapp_message_color_text | color_opacity: 0.2 }};

        --av-popup-color-bg: {{ options.av_popup_color_background }};
        --av-popup-color-text: {{ options.av_popup_color_background | color_contrast: "#FFFFFF", "#222222" }};
        --av-popup-color-button-accept-bg: {{ options.av_popup_color_button_accept }};
        --av-popup-color-button-accept-text: {{ options.av_popup_color_button_accept | color_contrast: "#FFFFFF", "#222222" }};
        --av-popup-color-button-reject-bg: {{ options.av_popup_color_button_reject }};
        --av-popup-color-button-reject-text: {{ options.av_popup_color_button_reject | color_contrast: "#FFFFFF", "#222222" }};

        --breadcrumbs-margin-top: {{ options.bc_margin_top }}px;
        --breadcrumbs-margin-bottom: {{ options.bc_margin_bottom }}px;
        --breadcrumbs-alignment-desktop: {{ options.text_alignment_bc_desktop }};
        --breadcrumbs-alignment-mobile: {{ options.text_alignment_bc_mobile }};

        --color-discount: {{ options.color_discount }};
        --color-discount-text: {{ options.color_discount_text }};
        --color-ratings: {{ options.color_ratings }};
        --color-additional-icon: {{ options.color_additional_icon }};
        --color-additional-icon-active: {{ options.color_additional_icon_active }};
        --color-additional-background: {{ options.color_additional_background }};
        --color-additional-border: {{ options.color_additional_icon | color_opacity: 0.1 }};

        --carousel-nav-size: {{ options.theme_nav_size }}px;

        --theme-pb-image-transition: var(--theme-image-{{ options.pb_image_transition | default: 'none' }});
        --theme-pb-image-transition-hover: var(--theme-image-{{ options.pb_image_transition | default: 'none' }}-hover);
      }

      {% for color in options.color.bundles %}
      {% if options.pb_card and color.label == options.pb_card_bundle_color %}.product-block,{% endif %}
      [data-bundle-color="{{ color.label }}"] {
        --color-background: {{ color.options.background }};
        --color-background-contrast: {{ color.options.background | color_contrast: "#FFFFFF", "#222222" }};
        --color-background-contrast-op05: {{ color.options.background | color_contrast: "#FFFFFF", "#222222" | color_opacity: 0.05 }};
        --color-background-contrast-op3: {{ color.options.background | color_contrast: "#FFFFFF", "#222222" | color_opacity: 0.3 }};
        --color-background-contrast-op7: {{ color.options.background | color_contrast: "#FFFFFF", "#222222" | color_opacity: 0.7 }};
        --color-background-op0: {{ color.options.background | color_opacity: 0 }};
        --color-main: {{ color.options.main }};
        --color-main-op05: {{ color.options.main | color_opacity: 0.05 }};
        --color-main-op1: {{ color.options.main | color_opacity: 0.1 }};
        --color-main-op2: {{ color.options.main | color_opacity: 0.2 }};
        --color-main-op3: {{ color.options.main | color_opacity: 0.3 }};
        --color-main-op5: {{ color.options.main | color_opacity: 0.5 }};
        --color-main-op7: {{ color.options.main | color_opacity: 0.7 }};
        --color-secondary: {{ color.options.secondary }};
        --color-secondary-op05: {{ color.options.secondary | color_opacity: 0.05 }};
        --color-secondary-op1: {{ color.options.secondary | color_opacity: 0.1 }};
        --color-secondary-op3: {{ color.options.secondary | color_opacity: 0.3 }};
        --color-secondary-op7: {{ color.options.secondary | color_opacity: 0.7 }};
        --color-links: {{ color.options.links }};
        --color-links-hover: {{ color.options.main }};
        --color-links-badge-hover: {{ color.options.links | color_lighten: 5 }};
        --color-links-contrast: {{ color.options.links | color_contrast: "#FFFFFF", "#222222" }};
        --color-button-main-bg: {{ color.options.main_button_background }};
        --color-button-main-bg-hover: {{ color.options.main_button_background | color_lighten: 12.5 }};
        --color-button-main-text: {{ color.options.main_button_text }};
        --color-button-secondary-bg: {{ color.options.secondary_button_background }};
        --color-button-secondary-bg-hover: {{ color.options.secondary_button_background | color_lighten: 12.5 }};
        --color-button-secondary-text: {{ color.options.secondary_button_text }};
        --color-border: var(--color-main-op1);
        --color-selection-text: {{ color.options.main | color_contrast: "#FFFFFF", "#222222" }};
        --color-overlay: {{ color.options.background }};

        color: var(--color-main);
        background: var(--color-background);
      }
      {% endfor %}

      {% if options.pb_show_sku == false and options.pb_show_brand == false %}
      :is(.product-block__attributes, .store-product__attributes) {
        display: none !important;
      }
      {% elsif options.pb_show_sku == false and options.pb_show_brand %}
      .product-block__attributes:has(.product-block__brand:empty),
      .store-product__attributes:has(.store-product__brand:empty),
      :is(.product-block__sku, .store-product__sku),
      :is(.product-block__attributes, .store-product__attributes) > span:nth-child(2) {
        display: none !important;
      }
      {% elsif options.pb_show_sku and options.pb_show_brand == false %}
      .product-block__attributes:has(.product-block__sku:empty),
      .store-product__attributes:has(.store-product__sku:empty),
      :is(.product-block__brand, .store-product__brand),
      :is(.product-block__attributes, .store-product__attributes) > span:nth-child(2) {
        display: none !important;
      }
      {% endif %}

      .product-block__labels,
      .product-block__labels > .d-flex {
        align-items: {{ options.pb_labels_position }};
      }

      {% case options.pb_labels_shape %}
        {% when 'rectangular' %}
          .product-block__label--status,
          .product-block__label--new {
            border-radius: 0px;
          }
        {% when 'rounded' %}
          .product-block__label--status,
          .product-block__label--new {
            border-radius: calc(var(--pb-padding) * 0.5);
          }
      {% endcase %}

      {% if options.pb_labels_position == 'start' %}
        .product-block:has(.product-block__extras) .product-block__extras {
          right: 0;
        }

        @media screen and (max-width: 575px) {
          .product-block:has(.product-block__extras) .product-block__extras > * {
            right: calc(var(--pb-padding) * 2.5);
          }
        }

        @media screen and (min-width: 576px) {
          .product-block:has(.product-block__extras) .product-block__extras > * {
            right: calc(var(--pb-padding) * 3);
          }
        }
      {% else %}
        .product-block:has(.product-block__extras) .product-block__extras {
          left: 0;
        }

        @media screen and (max-width: 575px) {
          .product-block:has(.product-block__extras) .product-block__extras > * {
            left: calc(var(--pb-padding) * 2.5);
          }
        }

        @media screen and (min-width: 576px) {
          .product-block:has(.product-block__extras) .product-block__extras > * {
            left: calc(var(--pb-padding) * 3);
          }
        }
      {% endif %}

      {% if options.theme_icon_cart_button == false %}
      .product-block__form:has(.product-block__quantity.d-none) .product-block__button--add-to-cart > .theme-icon {
        display: none;
      }
      {% endif %}

      {% if options.hide_out_of_stock_variants %}
      .product-options__selector:has(input[type="radio"].disabled),
      .product-form .product-options__fieldset .select option.disabled {
        display: none !important;
      }
      {% endif %}

      {% if options.show_available_stock_tag %}
      .product-stock[data-label="available"] {
        display: inline-flex !important;
      }
      {% else %}
      .product-stock[data-label="available"] {
        display: none !important;
      }
      {% endif %}

      {% if options.show_exact_stock_amount %}
      .product-stock__text {
        display: none !important;
      }
      {% else %}
      .product-stock__text-exact {
        display: none !important;
      }
      {% endif %}

      {% if options.hide_out_of_stock_locations %}
      .product-stock-locations__status[data-label="out-of-stock"] {
        display: none !important;
      }
      {% endif %}

      {% if options.pf_buy_now_button_hide_disabled %}
      #buy-now-button:disabled {
        display: block !important;
        visibility: hidden !important;
      }

      @media screen and (max-width: 768px) {
        #buy-now-button:disabled {
          display: none !important;
        }
      }
      {% endif %}

      {% if options.disable_prices %}
      .product-price,
      .product-block__pricing,
      .store-product__pricing {
        display: none !important;
      }
      {% endif %}

      {% if options.pb_label_discount_enable == 'none' or options.disable_prices %}
      .product-block__label--discount {
        display: none !important;
      }
      {% else %}
        {% if options.pb_label_discount_enable == 'percentage' %}
          .product-block__discount-text {
            display: none !important;
          }
        {% elsif options.pb_label_discount_enable == 'text' %}
          .product-block__discount-percentage {
            display: none !important;
          }
        {% endif %}

        {% case options.pb_label_discount_shape %}
          {% when 'circular' %}
            .product-block__label--discount {
              width: 44px !important;
              height: 44px;
              flex-direction: column;
              align-items: center;
              justify-content: center;
              border-radius: 100%;
              text-align: center;
              row-gap: 1px;
            }
          {% when 'rectangular' %}
            .product-block__label--discount {
              flex-direction: row;
              gap: calc(var(--pb-padding) * 0.25);
            }
          {% when 'rounded' %}
            .product-block__label--discount {
              flex-direction: row;
              gap: calc(var(--pb-padding) * 0.25);
              border-radius: calc(var(--pb-padding) * 0.5);
            }
        {% endcase %}
      {% endif %}

      {% if options.pb_label_status == false %}
      .product-block__label--status  {
        display: none !important;
      }
      {% endif %}

      {% if options.disable_shopping_cart %}
      .product-block__actions,
      .store-product__actions {
        display: none !important;
      }
      {% endif %}

      {% unless options.theme_button_hover %}
        .button--style:before {
          display: none;
        }
      {% endunless %}

      {% unless options.pb_quickview_show_sku %}
      #product-quick-view .product-page__sku {
        display: none !important;
      }
      {% endunless %}

      {% unless options.pb_quickview_show_brand %}
      #product-quick-view .product-page__brand {
        display: none !important;
      }
      {% endunless %}

      {% unless options.pb_quickview_show_reviews %}
      #product-quick-view .product-page__reviews {
        display: none !important;
      }
      {% endunless %}

      {% unless options.pb_quickview_show_wishlist %}
      #product-quick-view .product-wishlist {
        display: none !important;
      }
      {% endunless %}

      {% unless options.pb_quickview_show_stock %}
      #product-quick-view .product-stock {
        display: none !important;
      }
      {% endunless %}

      {% unless options.pb_quickview_show_reviews %}
      #product-quick-view .product-ratings {
        display: none !important;
      }
      {% endunless %}

      {% unless options.pb_quickview_show_description %}
      #product-quick-view .product-page__description {
        display: none !important;
      }
      {% endunless %}

      {% if options.theme_tabs_uppercase %}
      .theme-tabs__item .button.theme-tabs__tab.button--bordered {
        text-transform: uppercase !important;
      }
      {% endif %}

      {% if options.theme_spacing == 'none' %}
        {% if options.theme_width == '100vw' %}
          {% assign theme_width_for_spacing = options.theme_width %}
        {% else %}
          {% assign theme_width = options.theme_width | remove: 'px' | times: 1 | round: 0 %}
          {% assign theme_width_for_spacing = theme_width | append: 'px' %}
          {% assign theme_width_for_spacing_min = theme_width_for_spacing | plus: 1 %}
        {% endif %}

        .theme-section__content:has(.theme-pack) {
          padding-right: var(--section-content-static-padding) !important;
          padding-left: var(--section-content-static-padding) !important;
        }

        /* Fixes for elements that need extra padding */
        @media screen and (max-width: 767px) {
          .theme-section:not(:has(.cart-area__content)) .theme-message,
          .theme-section__content > .theme-section__body {
            padding-right: calc(var(--section-content-static-padding) * 2) !important;
            padding-left: calc(var(--section-content-static-padding) * 2) !important;
          }

          .featured-image[data-display="carousel"] + .theme-section__column {
            padding-left: 0 !important;
          }
        }

        /* Fixes for Theme Spacing = None, with variable widths */
        @media screen and (max-width: {{ theme_width_for_spacing }}) {
          .theme-section__content:has(> #contact_form),
          .theme-section__content:has(> .contact-block),
          .theme-section__content:has(> .theme-section__body > .theme-accordion),
          .theme-section__content:has(> .theme-section__body > .theme-section__embed),
          .theme-section__content:has( *:is(.review-block, .contact-location, .testimony-block, .trustbar-block):not([data-card])),
          .theme-section__content:has(.theme-newsletter) {
            margin-right: 0 !important;
            margin-left: 0 !important;
          }

          .theme-section__content:has(.theme-block[data-spacing="false"][data-card="true"]) .theme-navigation,
          .theme-section__content-wrapper:not(.theme-section__content-wrapper--no-padding),
          .theme-section__content:has(.theme-accordion--subcategory),
          .theme-section__content:has(.theme-share),
          .theme-breadcrumbs {
            padding-right: var(--section-content-padding) !important;
            padding-left: var(--section-content-padding) !important;
          }

          .product-page__content,
          .theme-section__content > .theme-section__body:not(.theme-section__body--adjust) {
            padding-right: calc(var(--section-content-padding) * 2) !important;
            padding-left: calc(var(--section-content-padding) * 2) !important;
          }

          .featured-image[data-display="carousel"] + .theme-section__column {
            padding-right: 0 !important;
          }
        }

        @media screen and (min-width: 768px) and (max-width: {{ theme_width_for_spacing }}) {
          .product-page__wrapper[data-order-reversed="true"] .product-page__content {
            padding-right: calc(var(--section-content-padding) * 1) !important
          }
        }

        {% unless options.theme_width == '100vw' %}
          @media screen and (min-width: {{ theme_width_for_spacing_min }}px) {
            .theme-section__content:has(.theme-block[data-spacing="false"][data-card="true"]) .theme-navigation,
            .theme-section__content:has(*:is(.instagram-block, .category-block)[data-spacing="false"]) .theme-navigation,
            .theme-section__content .theme-section__column:has(> :is(.theme-accordion:not(.theme-accordion--subcategory), .theme-section__embed)) {
              padding-right: 0 !important;
              padding-left: 0 !important;
            }

            .theme-section--feed .theme-section__filters.d-md-block {
              padding-left: 0 !important;
            }

            .theme-section__content:has(.theme-section__column--has-media) {
              padding-right: var(--section-content-padding) !important;
              padding-left: var(--section-content-padding) !important;
            }
          }
        {% endunless %}
      {% endif %}

      {% case options.article_block_categories_icon %}
        {% when 'tag' %}
          .article-categories__icon::before {
            font-family: var(--icon-style-regular);
            content: "\e478";
          }
        {% when 'hashtag' %}
          .article-categories > .article-categories__link {
            gap: 0;
          }
          .article-categories__icon::before {
            font-family: var(--icon-style-regular);
            content: "\e2a2";
          }
        {% when 'none' %}
          .article-categories .article-categories__icon {
            display: none !important;
          }
      {% endcase %}

      {% if options.article_block_categories_badge %}
        .article-categories > .article-categories__link {
          padding: calc(var(--font-base-size) * 0.35) calc(var(--font-base-size) * 0.5);
          border-radius: var(--radius-style-adapt);
          background-color: var(--color-links) !important;
          color: var(--color-links-contrast) !important;
          line-height: 1;
        }

        .article-categories > .article-categories__link:hover {
          color: var(--color-links-contrast) !important;
          background-color: var(--color-links-badge-hover) !important;
        }
      {% endif %}
    {% endstyle %}

    <link rel="stylesheet" href="{{ 'app.css' | asset }}">
    {% if options.pb_quickview %}
      <link rel="stylesheet" href="{{ 'component-product.css' | asset }}">
    {% endif %}
    {% if is_customer_page %}<link rel="stylesheet" href="{{ 'customer.css' | asset }}">{% endif %}
    {% if is_checkout_page %}<link rel="stylesheet" href="{{ 'checkout.css' | asset }}">{% endif %}
    {% unless request.section_preview_mode %}
      {{ 'aos/2.3.4/aos.css' | public_asset_tag: 'rel="preload" as="style" onload="this.onload=null;this.rel=&#39;stylesheet&#39;"' }}
      <noscript>{{ 'aos/2.3.4/aos.css' | public_asset_tag }}</noscript>
    {% endunless %}

    {% render 'theme_data' %}

    {{ options.head_code_bottom }}
  </head>

  <body
    data-bundle-color="default"
    data-spacing="{{ options.theme_spacing }}"
    {% if options.theme_button_hover %}
      data-button-hover-style="{{ options.theme_button_hover_style }}"
    {% endif %}
    {% if options.theme_tabs_style == 'underline' %}
      data-tabs-style="underline"
    {% endif %}
  >
    <script src="{{ 'theme.js' | asset }}" defer></script>
    <script src="{{ 'custom.js' | asset }}" defer></script>
    {% if is_category_page %}<script src="{{ 'category.js' | asset }}" defer></script>{% endif %}

    <!-- Bootstrap JS -->
    {{ 'bootstrap/5.3.3/bootstrap.bundle.min.js' | public_asset_tag: 'defer' }}
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
        const tooltipList = [...tooltipTriggerList].map((tooltipTriggerEl) => new bootstrap.Tooltip(tooltipTriggerEl));
      });
    </script>

    {{ options.body_code_top }}

    <div class="main-container" data-layout="{{ template }}">
      <div class="toast-notification__wrapper {{ options.cart_notification_position }}"></div>
      {{ content }}
    </div>

    {% unless request.section_preview_mode %}
      {% render 'store_whatsapp' %}
      {% render 'popup_age_verification' %}

      {{ 'aos/2.3.4/aos.js' | public_asset_tag }}
      <script>
        AOS.init({
          once: false,
          mirror: true,
        });
      </script>
    {% endunless %}

    {% if options.pb_quickview %}
      {% render 'product_block_quick_view' %}
    {% endif %}

    {{ options.body_code_bottom }}

    {% comment %}
      ── GameQuest: Sincronización de saldo QuestPoints ────────────────────────
      FIX C-01: Bloque movido a ANTES de </body> (era inválido después de </body>)
      FIX C-02: Token corregido al PUBLIC_STORE_TOKEN real
      FIX C-03: Header x-store-token agregado al fetch (requerido por verify_public_token)
      FIX A-01: Envuelto en IIFE (evita contaminación de scope global)
      FIX A-02: Guard (d.saldo || 0) para evitar TypeError en null/undefined
      FIX A-03: Guard r.ok antes de parsear JSON
      FIX A-04: Guard readyState para navegación SPA / Back del browser
      FIX M-01: encodeURIComponent en el email de la URL
      FIX M-04: gc-modal-saldo también usa toLocaleString('es-CL')
      NOTA M-03: Esta URL también está en account.liquid y qp_header_badge.liquid
                 Si cambia, actualizar los 3 archivos.
      ─────────────────────────────────────────────────────────────────────────
    {% endcomment %}
    {% if customer %}
    <script>
      (function () {
        const GAMECOINS_API_URL = "https://gamecoins.onrender.com"; // M-03: también en account.liquid y qp_header_badge.liquid
        const MAIL              = "{{ customer.email | downcase | strip }}";
        const TOK               = "f98yWtYyIpvJDjLhnssu8ntuKfFSnA7NSft0NoaFZIE";

        async function syncBal() {
          const _ctrl  = new AbortController();                                         // FIX F-05
          const _timer = setTimeout(() => _ctrl.abort(), 8000);                        // FIX F-05
          try {
            const r = await fetch(
              `${GAMECOINS_API_URL}/api/public/balance/${encodeURIComponent(MAIL)}`,  // FIX M-01
              { headers: { 'x-store-token': TOK }, signal: _ctrl.signal }             // FIX C-03, F-05
            );
            clearTimeout(_timer);
            if (!r.ok) return;                                                          // FIX A-03
            const d = await r.json();
            const balEl = document.getElementById('gc-cart-balance');
            const modEl = document.getElementById('gc-modal-saldo');
            if (balEl) balEl.innerText = (d.saldo || 0).toLocaleString('es-CL');       // FIX A-02
            if (modEl) modEl.innerText = (d.saldo || 0).toLocaleString('es-CL');       // FIX M-04
          } catch (e) {
            if (e.name !== 'AbortError') console.error("GameCoins: Balance offline", e);  // FIX F-05
          }
        }

        // FIX A-04: Guard para bfcache / SPA / navegación Back
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', syncBal);
        } else {
          syncBal();
        }
      })();  // FIX A-01: IIFE
    </script>
    {% endif %}

  </body>
</html>
