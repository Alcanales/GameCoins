<script src="{{ 'cart.js' | asset }}" defer></script>

<section class="container-fluid cart-page" data-bundle-color="{{ options.cart_bundle_color }}">
  <div class="row cart-page__container">
    
    <div class="col-12 col-lg-8 cart-page__content">
      {% render 'cart_header' %}

      {% if customer == null and store.customers_enabled and store.customers_optional %}
        <div class="cart-page__message text-center">
          {% capture login_text -%}
            <a href="{{ customer_login_url }}" class="cart-page__link" title="{% t 'Log in to your account' %}">{% t "Log in" %}</a>
          {%- endcapture %}
          {%- t "Already have an account? You can %{login} here", login: login_text -%}
        </div>
      {% endif %}

      {{ index_for_components }}
    </div>

    <div class="col-12 col-lg-4 cart-summary{% if order.products_count == 0 %} cart-summary--empty{% endif %}">
      
      {% if customer %}
        <div class="card mb-3 border-0 shadow-sm" id="gamecoins-widget" style="display:none; border-left: 5px solid #D32F2F !important;">
          <div class="card-body p-3">
            <h5 class="mb-2 text-danger fw-bold"><i class="fas fa-coins"></i> CANJEAR GAMECOINS</h5>
            
            <div class="d-flex justify-content-between align-items-center mb-3">
              <span class="small text-muted fw-bold">Saldo Disponible:</span>
              <strong class="text-dark fs-5" id="gc-balance">...</strong>
            </div>
            
            <div class="input-group mb-2">
              <input type="number" id="gc-input" class="form-control fw-bold" placeholder="Monto" min="100">
              <button class="btn btn-danger fw-bold px-4" id="gc-btn" onclick="canjearDesdeCarrito()">USAR</button>
            </div>
            
            <div id="gc-msg" class="small fw-bold text-center mt-2 text-muted">Mínimo para canjear: $100 CLP</div>
          </div>
        </div>

        <script>
          const GC_API = "https://gamecoins.onrender.com";
          const GC_EMAIL = "{{ customer.email }}";
          const GC_TOKEN = "f98yWtYyIpvJDjLhnssu8ntuKfFSnA7NSft0NoaFZIE";
          let maxSaldoCart = 0;

          // Cargar Saldo
          fetch(`${GC_API}/api/public/balance/${GC_EMAIL}`, {
            headers: {
              'x-store-token': GC_TOKEN
            }
          })
            .then(r => r.json())
            .then(d => {
              if (d.saldo >= 100) {
                maxSaldoCart = d.saldo;
                document.getElementById('gc-balance').innerText = new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP' }).format(d.saldo);
                document.getElementById('gc-input').value = Math.floor(d.saldo);
                document.getElementById('gc-input').max = Math.floor(d.saldo);
                document.getElementById('gamecoins-widget').style.display = 'block';
              }
            }).catch(e => console.error('Error cargando GameCoins:', e));

          async function canjearDesdeCarrito() {
            const inp = document.getElementById('gc-input');
            const btn = document.getElementById('gc-btn');
            const msg = document.getElementById('gc-msg');
            const monto = Math.floor(Number(inp.value));

            if (!monto || monto < 100 || monto > maxSaldoCart) {
              msg.innerText = "Monto inválido o insuficiente";
              msg.className = "text-danger small fw-bold text-center mt-2";
              return;
            }

            inp.disabled = true;
            btn.disabled = true;
            msg.innerText = "Generando cupón y copiando...";
            msg.className = "text-warning small fw-bold text-center mt-2";

            try {
              const res = await fetch(`${GC_API}/api/canje`, {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'x-store-token': GC_TOKEN
                },
                body: JSON.stringify({ email: GC_EMAIL, monto: monto, cart_total: monto })
              });

              const data = await res.json();

              if (res.ok && data.status === 'ok') {
                const cuponGenerado = data.cupon_codigo;

                const mostrarExito = () => {
                  msg.innerText = "¡Cupón Generado!";
                  msg.className = "text-success small fw-bold text-center mt-2";
                  setTimeout(() => window.location.reload(), 1000); // Recarga para actualizar el saldo en pantalla
                };

                // Auto-copiado al portapapeles
                if (navigator.clipboard && navigator.clipboard.writeText) {
                  navigator.clipboard.writeText(cuponGenerado).then(() => {
                    alert(`✅ ¡Canje exitoso!\n\nTu cupón por $${monto} es: ${cuponGenerado}\n\n📋 ¡El código se ha COPIADO a tu portapapeles!\nYa puedes pegarlo en la casilla de descuentos.`);
                    mostrarExito();
                  }).catch(() => {
                    alert(`✅ ¡Canje exitoso!\n\nTu cupón es: ${cuponGenerado}\nAnótalo o cópialo manualmente para usarlo.`);
                    mostrarExito();
                  });
                } else {
                  alert(`✅ ¡Canje exitoso!\n\nTu cupón es: ${cuponGenerado}\nAnótalo o cópialo manualmente para usarlo.`);
                  mostrarExito();
                }

              } else {
                let errorMsg = 'Error al canjear';
                if (typeof data.detail === 'string') {
                    errorMsg = data.detail;
                } else if (Array.isArray(data.detail)) {
                    errorMsg = 'Datos incompletos en la petición.';
                }
                throw new Error(errorMsg);
              }
            } catch (e) {
              msg.innerText = "Error: " + e.message;
              msg.className = "text-danger small fw-bold text-center mt-2";
              inp.disabled = false;
              btn.disabled = false;
            }
          }
        </script>
      {% endif %}
      {% render 'cart_summary' %}
    </div>
  </div>
</section>