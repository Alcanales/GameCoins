# Copia como .env y completa los valores — NO subir .env al repo

DATABASE_URL=postgresql://user:password@host/dbname
ADMIN_USER=tu_usuario_admin
ADMIN_PASS=tu_password_seguro

# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
STORE_TOKEN=genera_token_seguro_aqui
PUBLIC_STORE_TOKEN=genera_otro_token_seguro_aqui

JS_LOGIN_CODE=tu_login_code_jumpseller
JS_AUTH_TOKEN=tu_auth_token_jumpseller
JUMPSELLER_HOOKS_TOKEN=tu_hooks_token_jumpseller

SMTP_EMAIL=contacto@tutienda.cl
SMTP_PASSWORD=tu_app_password_smtp
TARGET_EMAIL=contacto@tutienda.cl

USD_TO_CLP=1000
MIN_CANJE=100
MIN_PURCHASE_USD=3.0
BUYLIST_FACTOR_CREDITO=520
BUYLIST_FACTOR_CASH=400
COND_NM=1.0
COND_LP=0.85
COND_MP=0.70
COND_HP=0.50
COND_DMG=0.25
