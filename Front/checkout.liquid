<div class="col-12 col-lg-4 cart-summary{% if order.products_count == 0 %} cart-summary--empty{% endif %}">
  
  {% if customer and order.products_count > 0 %}
    <div style="margin-bottom:20px; padding:20px; background:#F3F4F6; border-radius:12px; text-align:center; border:1px dashed #ccc">
        <div style="display:flex; justify-content:center; align-items:center; gap:10px; margin-bottom:10px">
            <span style="font-size:11px; font-weight:bold; color:#6b7280; text-transform:uppercase">Tu Saldo QP</span>
            <span id="gc-cart-balance" style="font-size:18px; font-weight:900; color:#059669">...</span>
        </div>
        <button type="button" onclick="window.toggleGameCoinsModal()" style="background:#111; color:#fff; border-radius:50px; padding:12px; width:100%; font-weight:bold; border:none; cursor:pointer; font-size:14px; transition:0.2s">
            🎁 CANJEAR PUNTOS AHORA
        </button>
    </div>

    {% render 'jumpseller_dashboard' %}
  {% endif %}

  {% render 'cart_summary' %}
</div>